{
  "manifest_version": 3,
  "name": "JobHunt Auto Apply",
  "version": "1.1.1",
  "description": "Automatically fill job applications on Greenhouse and Lever using your JobHunt profile.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon":  "icons/icon48.png",
    "default_title": "JobHunt Auto Apply"
  },

  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://jobs.lever.co/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:38471/*"
  ]
}